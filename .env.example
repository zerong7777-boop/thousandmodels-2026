# App mode
APP_ENV=local
DEMO_MODE=true

# API security
APP_SECRET_KEY=
SESSION_COOKIE_SECURE=auto
SESSION_SAMESITE=lax
SESSION_TTL_HOURS=8
CSRF_MODE=demo
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Store
DATABASE_URL=sqlite:///./data/runtime/zhiyin.sqlite3
AUTO_MIGRATE=true

# Agent and optional Qwen controlled drafts
AGENT_BACKEND=deterministic
AGENT_DRAFT_BACKEND=deterministic
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen-plus

# Manual local QwenPaw smoke only
RUN_LIVE_QWENPAW_SMOKE=false
QWENPAW_BASE_URL=http://127.0.0.1:8088
QWENPAW_AGENT_ID=

# Web
VITE_API_BASE_URL=
VITE_DEMO_MODE=true
